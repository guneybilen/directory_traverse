


<h1>File Tree</h1>

<%= form_with(url: say_directories_path, method: "get", local: true) do |form| %>
  <div>
    <%= form.label :path, "Enter path" %>
    <%= form.text_field :path, value: params[:path], placeholder: "Enter path" %>
    <%= form.submit "Show Tree" %>
</div>
<% end %>

<% if flash[:error] %>
  <p style="color: red;">
    <%= flash[:error] %>
  </p>
<% end %>
  
<% if @file_tree.present? %>
  <%= render partial: "tree", locals: {tree: @file_tree} %>
<% end %>

